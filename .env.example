# =========================================
#  环境变量示例文件
#  使用方法：复制本文件为 .env 并填入真实值
#  切勿将 .env 提交到 git
# =========================================

# LLM API Key（示例：通义千问 DashScope）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 备选：OpenAI 兼容接口
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Java 服务地址（若需要主动回调 Java 服务时使用）
JAVA_SERVICE_BASE_URL=http://127.0.0.1:9000
