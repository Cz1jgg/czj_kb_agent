# =========================================
#  环境变量示例文件
#  使用方法：复制本文件为 .env 并填入真实值
#  切勿将 .env 提交到 git（已在 .gitignore 中忽略）
# =========================================
#  优先级：.env > 系统环境变量 > settings.yaml 默认值
# =========================================

# -------- 火山方舟豆包（推荐）/ OpenAI 兼容接口 --------
# 火山方舟豆包（字节跳动）：https://console.volcengine.com/ark
# 接入地址（OpenAI 兼容）：https://ark.cn-beijing.volces.com/api/v3
# 模型：doubao-lite-128k / doubao-pro-128k 等
ARK_API_KEY=your_ark_api_key_here
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# -------- LLM 与 Embedding 模型名称（可选，留空则使用 settings.yaml 默认值）--------

# LLM 模型：例如 qwen-plus / gpt-4o-mini / deepseek-chat
LLM_MODEL=
LLM_TEMPERATURE=

# Embedding 模型：例如 text-embedding-v2 / text-embedding-3-small
EMBEDDING_MODEL=

# -------- 服务与路径（可选，留空则使用 settings.yaml 默认值）--------

# 服务端口（默认 8000）
SERVER_PORT=
# 日志级别：DEBUG / INFO / WARNING / ERROR（默认 INFO）
LOG_LEVEL=

# 数据目录（使用相对路径时相对于项目根目录）
DOCUMENTS_DIR=
PARSED_DIR=
VECTOR_STORE_DIR=
LOGS_DIR=

# -------- Java 服务对接（若需要主动回调 Java 服务时使用）--------
JAVA_SERVICE_BASE_URL=http://127.0.0.1:9000
