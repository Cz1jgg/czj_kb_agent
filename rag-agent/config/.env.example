# 环境变量示例文件（复制为 .env 后填入真实值）
# LLM API Key
API_KEY=your_api_key_here

# 可选：自定义 API Base URL（例如通义千问、DeepSeek 等）
BASE_URL=https://api.openai.com/v1

# 服务端口（与 config.yaml 保持一致）
SERVICE_PORT=8000

# 数据存储路径（可按需更改）
DATA_DIR=data
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
FAISS_INDEX_DIR=data/faiss_index
LOG_DIR=logs
